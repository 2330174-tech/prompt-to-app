# Copy to .env and fill in. Get a FREE key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Model used for generation stages. gemini-2.0-flash is free + fast.
GEMINI_MODEL=gemini-2.0-flash

# "quality" uses a stronger model for the system-design stage (optional).
GEMINI_DESIGN_MODEL=gemini-2.0-flash

# If no key is set, the system runs in deterministic MOCK mode (no network).
